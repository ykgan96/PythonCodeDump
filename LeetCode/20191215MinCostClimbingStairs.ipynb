   "source": [
    "def MCCS(cost):\n",
    "    if len(cost)==2:\n",
    "        return min(cost)\n",
    "    \n",
    "    tc = [0 for i in range(len(cost)+1)]\n",
    "    for i in range(2,len(cost)+1):\n",
    "        tc[i] = min(cost[i-2]+tc[i-2],cost[i-1]+tc[i-1])\n",
    "        \n",
    "    return tc[-1]"
   ]
  },
